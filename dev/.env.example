# ── Family Dashboard local dev environment ────────────────────────────────────
# Copy this file to dev/.env and fill in your values.
# dev/.env is gitignored — never commit real tokens.

# Your live HA dashboard URL (for proxying API calls)
HA_URL=https://dashboard.fna3.net

# A HA long-lived access token (Settings → Profile → Long-Lived Access Tokens)
# Used by the backend to call HA APIs (person entities, calendar, etc.)
# Required for run-backend.py; optional for proxy.py
HA_TOKEN=your_long_lived_token_here

# Skip the login screen when using the frontend-only proxy (1 = skip, 0 = show)
SKIP_AUTH=1

# Local port for the dev server
# Default: 8099 (HTTP) or 8443 (HTTPS)
PORT=8099

# Enable HTTPS for camera access on phones (1 = yes, 0 = no)
# Generates a self-signed cert in dev/certs/ on first run.
# Or use --https flag:  python dev/proxy.py --https
USE_HTTPS=0

# ── For full offline dev with mock HA ─────────────────────────────────────────
# Run mock-ha.py in a separate terminal, then change HA_URL:
# HA_URL=http://localhost:8088
# HA_TOKEN=fake-token
